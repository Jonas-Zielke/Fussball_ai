# ── Python virtual environment (4.8 GB, regenerable from requirements.txt) ──
venv/
.venv/
env/
ENV/

# ── Python bytecode / caches ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Test / type / lint caches ──
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Jupyter ──
.ipynb_checkpoints/

# ── Packaging / build artifacts ──
build/
dist/
*.egg-info/
.eggs/

# ── Claude Code local (machine-specific permission allowlist) ──
.claude/settings.local.json

# ── Editor / IDE ──
.idea/
.vscode/
*.swp
*~

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini

# ── Secrets (never commit API keys) ──
.env
.env.*
!.env.example

# NOTE: data/ and models/ ARE tracked intentionally — this is a local-only
# snapshot repo, so trained checkpoints and processed datasets are kept for
# full reproducibility/rollback. Largest file ~13 MB; no Git LFS needed.
